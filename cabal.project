-- Custom repository for cardano haskell packages, see CONTRIBUTING for more
repository cardano-haskell-packages
  url: https://chap.intersectmbo.org/
  secure: True
  root-keys:
    3e0cce471cf09815f930210f7827266fd09045445d65923e6d0238a6cd15126f
    443abb7fb497a134c343faf52f0b659bd7999bc06b7f63fa76dc99d631f9bea1
    a86a1f6ce86c449c46666bda44268677abf29b5b2d2eb5ec7af903ec2f117a82
    bcec67e8e99cabfa7764d75ad9b158d72bfacf70ca1d0ec8bc6b4406d1bf8413
    c00aae8461a256275598500ea0e187588c35a5d5d7454fb57eac18d9edb86a56
    d4a35cd3121aa00d18544bb0ac01c3e1691d618f462c46129271bccf39f7e8ee

-- See CONTRIBUTING for some Nix commands you will need to run if you
-- update either of these.
index-state:
  -- Bump this if you need newer packages from Hackage
  , hackage.haskell.org 2025-05-15T07:59:00Z
  -- Bump this if you need newer packages from CHaP
  , cardano-haskell-packages 2025-05-15T08:36:14Z

packages:
  ouroboros-consensus
  ouroboros-consensus-cardano
  ouroboros-consensus-protocol
  ouroboros-consensus-diffusion
  ouroboros-consensus-observe
  sop-extras
  strict-sop-core
  -- ../leios-prototype-cardano-ledger/eras/allegra/impl
  -- ../leios-prototype-cardano-ledger/eras/alonzo/impl
  -- ../leios-prototype-cardano-ledger/eras/alonzo/test-suite
  -- ../leios-prototype-cardano-ledger/eras/babbage/impl
  -- ../leios-prototype-cardano-ledger/eras/babbage/test-suite
  -- ../leios-prototype-cardano-ledger/eras/conway/impl
  -- ../leios-prototype-cardano-ledger/eras/conway/test-suite
  -- ../leios-prototype-cardano-ledger/eras/mary/impl
  -- ../leios-prototype-cardano-ledger/eras/shelley/impl
  -- ../leios-prototype-cardano-ledger/eras/shelley/test-suite
  -- ../leios-prototype-cardano-ledger/eras/shelley-ma/test-suite
  -- ../leios-prototype-cardano-ledger/libs/cardano-ledger-api
  -- ../leios-prototype-cardano-ledger/libs/cardano-ledger-core
  -- ../leios-prototype-cardano-ledger/libs/cardano-ledger-binary
  -- ../leios-prototype-cardano-ledger/libs/cardano-protocol-tpraos
  -- ../leios-prototype-cardano-ledger/libs/non-integral
  -- ../leios-prototype-cardano-ledger/libs/small-steps
  -- ../leios-prototype-cardano-ledger/libs/cardano-data
  -- ../leios-prototype-cardano-ledger/libs/set-algebra
  -- ../leios-prototype-cardano-ledger/libs/vector-map
  -- ../leios-prototype-cardano-ledger/eras/byron/chain/executable-spec
  -- ../leios-prototype-cardano-ledger/eras/byron/ledger/executable-spec
  -- ../leios-prototype-cardano-ledger/eras/byron/ledger/impl
  -- ../leios-prototype-cardano-ledger/eras/byron/ledger/impl/test
  -- ../leios-prototype-cardano-ledger/eras/byron/crypto
  -- ../leios-prototype-cardano-ledger/eras/byron/crypto/test
  -- ../leios-prototype-cardano-ledger/libs/cardano-ledger-test
  -- ../leios-prototype-cardano-ledger/libs/ledger-state
  -- ../leios-prototype-cardano-ledger/libs/constrained-generators

-- We want to always build the test-suites and benchmarks
tests: true
benchmarks: true

multi-repl: True

import: ./asserts.cabal

package ouroboros-network
  -- Certain ThreadNet tests rely on transactions to be submitted promptly after
  -- a node (re)start. Therefore, we disable this flag (see
  -- https://github.com/IntersectMBO/ouroboros-network/issues/4927 for context).
  flags: -txsubmission-delay

-- We need to disable bitvec's SIMD for now, as it breaks during cross compilation.
if(os(windows))
  constraints:
    bitvec -simd

if impl (ghc >= 9.12)
  allow-newer:
    -- Bounds will be relaxed in next release
    , network-mux:base
    , ouroboros-network-api:base
    , ouroboros-network-framework:base
    , ouroboros-network-protocols:base
    , ouroboros-network:base

    -- https://github.com/phadej/vec/issues/118
    , bin:base
    , fin:base
    , ral:base

    -- https://github.com/haskellari/tree-diff/issues/97
    , tree-diff:base

    -- https://github.com/kapralVV/Unique/issues/11
    , Unique:hashable

-- Points to ouroboros-network/nfrisby/leios-202511-demo
source-repository-package
  type: git
  location: https://github.com/IntersectMBO/ouroboros-network.git
  tag: fb5f16f48af84950db0c2ecefd8cbda532c77d1a
  --sha256: sha256-0LWD1zwOzhdcPJtBuw7pRDVcBd9CKJOFjm9o4BvsIMM=
  subdir:
    cardano-ping
    monoidal-synchronisation
    quickcheck-monoids
    network-mux
    ouroboros-network
    ouroboros-network-api
    ouroboros-network-framework
    ouroboros-network-mock
    ouroboros-network-protocols
    ouroboros-network-testing
    ntp-client
    cardano-client

-- Points to cardano-ledger/leios-prototype
source-repository-package
  type: git
  location: https://github.com/IntersectMBO/cardano-ledger.git
  tag: 1327573bfb86f7e596151f77d03fc38982be8749
  --sha256: sha256-CzA6eucrpsc8WMAtG9aNP0DcGtCxghHe0HSX+Yxvcd8=
  subdir:
    eras/allegra/impl
    eras/alonzo/impl
    eras/alonzo/test-suite
